					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"full_name\": \"Jane Doe\",\n    \"dob\": \"1995-05-15\",\n    \"gender\": \"female\",\n    \"relationship\": \"daughter\",\n    \"parent_id\": null,\n    \"is_alive\": true,\n    \"married_date\": null,\n    \"photo\": null,\n    \"note\": \"This is my daughter\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/family-tree",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"family-tree"
					]
				},
				"description": "Adds a new member to the family tree. \n\n**Fields:**\n- `relationship`: son, daughter, partner, spouse, father, mother\n- `gender`: male, female\n- `is_alive`: boolean"
			},
			"response": []
		},
