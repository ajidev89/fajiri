        "name": "Fajiri Family Tree API",
        "description": "API documentation for the Family Tree module in the Fajiri platform. Includes endpoints for managing relatives and building a hierarchical family structure.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "List Family Members",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/family-tree",
                    "host": ["{{base_url}}"],
                    "path": ["api", "family-tree"]
                },
                "description": "Fetches a nested list of all family members for the authenticated user. Includes hierarchical relationships (children)."
            },
            "response": [
                {
                    "name": "Success Response",
                    "originalRequest": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/family-tree",
                            "host": ["{{base_url}}"],
                            "path": ["api", "family-tree"]
                        }
                    },
                    "status": "OK",
                    "code": 200,
                    "_postman_previewlanguage": "json",
                    "header": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        }
                    ],
                    "cookie": [],
                    "body": "{\n    \"data\": [\n        {\n            \"id\": 1,\n            \"user_id\": 10,\n            \"parent_id\": null,\n            \"full_name\": \"John Doe Senior\",\n            \"dob\": \"1965-05-20\",\n            \"gender\": \"male\",\n            \"photo\": \"https://res.cloudinary.com/demo/image/upload/v12345678/father.jpg\",\n            \"relationship\": \"father\",\n            \"married_date\": \"1990-10-12\",\n            \"is_alive\": true,\n            \"death_date\": null,\n            \"note\": \"My father\",\n            \"children\": [\n                {\n                    \"id\": 2,\n                    \"user_id\": 10,\n                    \"parent_id\": 1,\n                    \"full_name\": \"Jane Doe Smith\",\n                    \"dob\": \"1995-03-15\",\n                    \"gender\": \"female\",\n                    \"photo\": \"https://res.cloudinary.com/demo/image/upload/v12345678/sister.jpg\",\n                    \"relationship\": \"daughter\",\n                    \"married_date\": null,\n                    \"is_alive\": true,\n                    \"death_date\": null,\n                    \"note\": \"My sister (registered as father's daughter)\",\n                    \"children\": [],\n                    \"created_at\": \"2026-04-21T10:00:00.000000Z\",\n                    \"updated_at\": \"2026-04-21T10:00:00.000000Z\"\n                }\n            ],\n            \"parent\": null,\n            \"created_at\": \"2026-04-21T10:00:00.000000Z\",\n            \"updated_at\": \"2026-04-21T10:00:00.000000Z\"\n        }\n    ],\n    \"message\": \"Family tree fetched successfully\",\n    \"status\": true\n}"
                }
            ]
        },
        {
            "name": "Add Family Member",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "full_name",
                            "value": "Jane Doe",
                            "type": "text"
                        },
                        {
                            "key": "dob",
                            "value": "1995-05-15",
                            "type": "text"
                        },
                        {
                            "key": "gender",
                            "value": "female",
