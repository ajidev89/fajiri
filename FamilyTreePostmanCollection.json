                            "description": "Optional parent ID for hierarchy"
                        },
                        {
                            "key": "is_alive",
                            "value": "1",
                            "type": "text"
                        },
                        {
                            "key": "photo",
                            "type": "file",
                            "src": "",
                            "description": "Image file to upload to Cloudinary"
                        },
                        {
                            "key": "note",
                            "value": "This is my daughter",
                            "type": "text"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/api/family-tree",
                    "host": ["{{base_url}}"],
                    "path": ["api", "family-tree"]
                },
                "description": "Adds a new member to the family tree. Supports Cloudinary photo upload via multipart/form-data.\n\n**Fields:**\n- `relationship`: son, daughter, partner, spouse, father, mother\n- `gender`: male, female\n- `is_alive`: 1 (true) or 0 (false)\n- `photo`: File (image)"
            },
            "response": []
        },
